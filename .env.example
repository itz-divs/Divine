# Divine Health Care - Environment Variables
# Copy this file to .env and fill in your values.

# Resend API Key (get yours at https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# Admin email to receive appointment notifications
ADMIN_EMAIL=divineicu@gmail.com

# Sender email (use onboarding@resend.dev for testing, or your verified domain)
FROM_EMAIL=Divine Health Care <onboarding@resend.dev>

# Server port (optional, defaults to 3001)
PORT=3001
